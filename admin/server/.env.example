# Server
PORT=4000
NODE_ENV=development
# Base URL used to build absolute image URLs (e.g. http://localhost:4000/uploads/products/x.jpg)
BASE_URL=http://localhost:4000

# MongoDB (local dev). For Atlas/Hostinger use the full SRV/URI.
MONGODB_URI=mongodb://127.0.0.1:27017/ecom

# JWT secrets (change these in production)
JWT_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Uploads
UPLOAD_PATH=uploads

# Firebase (ONLY for verifying Google Sign-In ID tokens on the storefront phase).
# Provide the project id; for verification you also need a service-account key file
# path (GOOGLE_APPLICATION_CREDENTIALS) OR set FIREBASE_SERVICE_ACCOUNT to the JSON.
FIREBASE_PROJECT_ID=e-commerce-app-2e61e
# GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# CORS (comma-separated allowed origins; * allows all in dev)
CORS_ORIGINS=*

# Seed admin (npm run seed)
SEED_ADMIN_EMAIL=admin@ecom.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=App Admin
